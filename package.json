{
  "name": "vc-platform-monorepo",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "bunx --bun drizzle-kit generate --config packages/database/drizzle.config.ts",
    "db:migrate": "bunx --bun drizzle-kit migrate --config packages/database/drizzle.config.ts",
    "db:studio": "bunx --bun drizzle-kit studio --config packages/database/drizzle.config.ts",
    "docker:up": "docker compose --env-file .env -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose --env-file .env -f docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/node": "latest",
    "drizzle-kit": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
